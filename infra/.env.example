ENVIRONMENT=local
APP_ENV_FILE=.env.example
CAD_BACKEND=cadquery
TEMPLATE_VERSION=cadquery-glb-v1
MODEL_SYNC_GENERATION=true
AUTO_CREATE_SCHEMA=true
ADMIN_API_KEY=replace-with-local-admin-key
REQUIRE_REDIS_FOR_READY=false
DATABASE_URL=postgresql+psycopg://fastener_user:replace-with-local-postgres-password@postgres:5432/fastener_cad
POSTGRES_DB=fastener_cad
POSTGRES_USER=fastener_user
POSTGRES_PASSWORD=replace-with-local-postgres-password
MINIO_ROOT_USER=replace-with-local-minio-user
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
ARTIFACT_BASE_DIR=storage/artifacts
RAW_ASSET_BASE_DIR=storage/raw-assets
PUBLIC_ARTIFACT_PREFIX=/artifacts
PUBLIC_RAW_ASSET_PREFIX=/raw-assets
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=104857600
STORAGE_BACKEND=local
S3_BUCKET=replace-with-artifact-bucket-name
REDIS_URL=redis://redis:6379/0
