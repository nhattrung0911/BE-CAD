ENVIRONMENT=production
APP_ENV_FILE=.env.production.example
CAD_BACKEND=cadquery
MODEL_SYNC_GENERATION=false
AUTO_CREATE_SCHEMA=false
REQUIRE_REDIS_FOR_READY=true
TEMPLATE_VERSION=cadquery-glb-v1
DATABASE_URL=postgresql+psycopg://fastener_user:CHANGE_ME@postgres:5432/fastener_cad
POSTGRES_DB=fastener_cad
POSTGRES_USER=fastener_user
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
STORAGE_BACKEND=s3
S3_BUCKET=replace-with-artifact-bucket-name
S3_PUBLIC_BASE_URL=https://cdn.example.com/cad-assets
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_ENDPOINT_URL=http://minio:9000
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
ADMIN_API_KEY=CHANGE_TO_32_CHAR_RANDOM_STRING
CORS_ALLOW_ORIGINS=https://mecsu.vn,https://www.mecsu.vn
MAX_UPLOAD_BYTES=104857600
